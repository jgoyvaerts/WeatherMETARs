    "@types/tz-lookup": "^6.1.2",
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "husky": "^9.1.7",
    "nitro": "^3.0.260522-beta",
    "node-gyp": "^12.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.3",
